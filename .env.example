# ── Vyakhya environment ──────────────────────────────────────────────
# Copy to .env (or let ./setup.sh generate it). Never commit .env.

# Encryption key used to encrypt provider API keys at rest (AES-256-GCM).
# setup.sh generates a strong random value. KEEP THIS SECRET AND BACKED UP —
# losing it makes stored provider keys unrecoverable (just re-enter them).
VYAKHYA_ENCRYPTION_KEY=

# API key gating the backend /api routes (sent as the X-API-Key header).
# The frontend build embeds VITE_API_KEY (same value). Leave all three blank to
# disable auth for local dev. setup.sh generates them for production.
VYAKHYA_API_KEY=
VITE_API_KEY=
# Shared key between the backend and the render service.
RENDER_API_KEY=

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=vyakhya
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vyakhya
DATABASE_URL=postgresql://vyakhya:change-me@postgres:5432/vyakhya

# ── Object storage (MinIO / S3) ──────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=vyakhya
S3_SECRET_KEY=change-me
S3_BUCKET=vyakhya

# ── Services ─────────────────────────────────────────────────────────
API_PORT=8000
WEB_PORT=5173
RENDER_PORT=8080
RENDER_SERVICE_URL=http://render:8080
# Set true to delegate real renders to the Node render service (else simulated).
USE_RENDER_SERVICE=false

# ── App ──────────────────────────────────────────────────────────────
# Provider API keys are NOT set here — add them in the Model Config UI.
LOG_LEVEL=info
