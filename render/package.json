{
  "name": "@vyakhya/render",
  "version": "0.1.0",
  "description": "Vyakhya render service \u2014 Scene-JSON \u2192 compile \u2192 lint \u2192 render \u2192 MP4",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
